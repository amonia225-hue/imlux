APP_NAME="PROJET IM'LUX"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://imlux.ci

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

# Sécurité : en prod APP_DEBUG doit rester false (sinon fuite d'informations)
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning

# ===== BASE DE DONNÉES =====
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=imlux_prod
DB_USERNAME=imlux_user
DB_PASSWORD=__CHANGER_MOI__

# Chemin vers mysqldump si non présent dans le PATH (pour `php artisan db:backup`)
# MYSQLDUMP_PATH=/usr/bin/mysqldump

# ===== SESSION / CACHE / QUEUE =====
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_ENCRYPT=true

CACHE_STORE=database
QUEUE_CONNECTION=database

# ===== MAIL (configurer un vrai SMTP) =====
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="no-reply@imlux.ci"
MAIL_FROM_NAME="${APP_NAME}"

# ===== FIREBASE CLOUD MESSAGING (notifications push) =====
FCM_PROJECT_ID=
FCM_CREDENTIALS=storage/app/firebase/service-account.json

VITE_APP_NAME="${APP_NAME}"
